#!/bin/bash

# ==============================================================================
# SCRIPT D'INSTALLATION AUTOMATIQUE SNMPv3 (VERSION BLINDÉE)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. PARAMÈTRES (Modifie ces valeurs - ATTENTION : 8 caractères minimum !)
# ------------------------------------------------------------------------------
SNMP_USER="admin_snmp"
SNMP_AUTH_PASS="AuthPassword123"
SNMP_PRIV_PASS="PrivPassword123"

# Vérification des droits root
if [ "$EUID" -ne 0 ]; then
  echo "Erreur : Ce script doit être exécuté en tant que root (utilise sudo)."
  exit 1
fi

echo "=> Début de l'installation blindée de SNMPv3..."

# ------------------------------------------------------------------------------
# 2. INSTALLATION DES PAQUETS
# ------------------------------------------------------------------------------
echo "=> Mise à jour et installation des paquets..."
apt-get update
# On ajoute psmisc pour s'assurer d'avoir la commande killall
apt-get install -y snmp snmpd libsnmp-dev psmisc

# ------------------------------------------------------------------------------
# 3. ARRÊT DU SERVICE ET NETTOYAGE DES PROCESSUS FANTÔMES
# ------------------------------------------------------------------------------
echo "=> Arrêt du service et libération du port 161..."
systemctl stop snmpd
# On force l'arrêt des processus récalcitrants en silence
killall -9 snmpd 2>/dev/null 

# ------------------------------------------------------------------------------
# 4. CRÉATION DE L'UTILISATEUR
# ------------------------------------------------------------------------------
echo "=> Création de l'utilisateur SNMPv3 sécurisé ($SNMP_USER)..."
net-snmp-create-v3-user -ro -a SHA -A "$SNMP_AUTH_PASS" -x AES -X "$SNMP_PRIV_PASS" "$SNMP_USER"

# ------------------------------------------------------------------------------
# 5. CONFIGURATION INFAILLIBLE DE L'ÉCOUTE RÉSEAU
# ------------------------------------------------------------------------------
echo "=> Configuration de l'écoute stricte sur 0.0.0.0:161..."
CONF_FILE="/etc/snmp/snmpd.conf"
cp $CONF_FILE "${CONF_FILE}.bak"

# On neutralise TOUTES les lignes agentaddress existantes (majuscules ou minuscules)
sed -i '/^[[:space:]]*agent[aA]ddress/s/^/#/' $CONF_FILE

# On ajoute notre ligne propre à la fin du fichier (avec la bonne orthographe UDP !)
echo "" >> $CONF_FILE
echo "# --- CONFIGURATION AUTOMATISÉE ---" >> $CONF_FILE
echo "agentAddress udp:0.0.0.0:161" >> $CONF_FILE

# ------------------------------------------------------------------------------
# 6. DÉMARRAGE ET ACTIVATION DU SERVICE
# ------------------------------------------------------------------------------
echo "=> Démarrage du service snmpd..."
systemctl start snmpd
systemctl enable snmpd

# ------------------------------------------------------------------------------
# 7. VÉRIFICATION FINALE AUTOMATIQUE
# ------------------------------------------------------------------------------
echo "=> Vérification de l'état du port..."
sleep 2

# Le script vérifie lui-même si le port est bien pris par le 0.0.0.0
if ss -ulnp | grep -q "0.0.0.0:161"; then
    echo "--------------------------------------------------------"
    echo " ✅ SUCCÈS : Le service écoute parfaitement sur 0.0.0.0:161 !"
    echo "--------------------------------------------------------"
else
    echo "--------------------------------------------------------"
    echo " ❌ ERREUR : Le port 161 n'est pas ouvert correctement."
    echo " Lance 'sudo systemctl status snmpd' pour voir le problème."
    echo "--------------------------------------------------------"
    exit 1
fi

echo "=> Test local de communication SNMPv3 :"
snmpwalk -v3 -u "$SNMP_USER" -l authPriv -a SHA -A "$SNMP_AUTH_PASS" -x AES -X "$SNMP_PRIV_PASS" localhost system | head -n 3
echo ""
echo "=> Installation terminée ! Tu peux aller l'ajouter dans Zabbix."
